# ── Backboard ─────────────────────────────────────────────────────────────────
BACKBOARD_API_KEY=your-backboard-api-key-here
# Populated automatically on first run — DO NOT delete once set
BACKBOARD_ASSISTANT_ID=

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-secret

# ── AWS / LocalStack ──────────────────────────────────────────────────────────
# For local dev with docker-compose, use these LocalStack defaults:
AWS_ENDPOINT_URL=http://localhost:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=us-east-1

# For production AWS, remove AWS_ENDPOINT_URL and set real credentials:
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...
# AWS_DEFAULT_REGION=us-east-1

# ── S3 bucket ─────────────────────────────────────────────────────────────────
S3_BUCKET=db-host-databases

# ── STS broker (SDK: POST /databases/s3-session) ──────────────────────────────
# ./start.sh runs scripts/bootstrap-localstack-sts.sh and exports this for LocalStack.
# If you start the API without start.sh, set the role ARN (after bootstrap once):
# DB_HOST_S3_ASSUMABLE_ROLE_ARN=arn:aws:iam::000000000000:role/db-host-tenant-s3

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
# Used in downloaded client .env templates
PUBLIC_API_BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
